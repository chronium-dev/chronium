{
	"files.associations": {
		"*.css": "tailwindcss"
	},
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.formatOnSave": true,
	"[svelte]": {
		"editor.defaultFormatter": "svelte.svelte-vscode"
	},
	"search.exclude": {
		"**/.svelte-kit/**": true,
		"**/node_modules/**": true,
		"**/build/**": true
	},
	"js/ts.tsdk.path": "node_modules\\typescript\\lib"
}
