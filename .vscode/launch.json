{
	"version": "0.2.0",
	"compounds": [
		{
			"name": "SvelteKit Full Stack",
			"configurations": ["SvelteKit Server", "SvelteKit Browser"]
		}
	],
	"configurations": [
		{
			"type": "node",
			"request": "launch",
			"name": "SvelteKit Server",
			"runtimeExecutable": "pnpm",
			"runtimeArgs": ["run", "dev"],
			"console": "integratedTerminal",
			"env": {
				"NODE_ENV": "development"
			},
			"skipFiles": ["<node_internals>/**"]
		},
		{
			"type": "chrome",
			"request": "launch",
			"name": "SvelteKit Browser",
			"url": "http://localhost:5173",
			"webRoot": "${workspaceFolder}",
			"sourceMaps": true
		}
	]
}
